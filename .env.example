# ============================================================
# 몽글픽 관리자 환경변수 템플릿 (.env.example)
# ============================================================
# 이 파일을 복사하여 .env로 만든 뒤 실제 값을 입력하세요:
#   cp .env.example .env
# Vite 환경변수는 VITE_ 접두사 필수
# ============================================================

# ── 서비스별 URL (직접 호출, 프록시 없음) ──
# 개발: 각 서비스 포트 명시. 운영(Nginx): 모두 비워두면 상대 경로 사용.
VITE_BACKEND_URL=http://localhost:8080
VITE_AGENT_URL=http://localhost:8000
